{
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "prisma generate && npm run build --prefix frontend",
    "start": "npm run start --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:check": "node scripts/check-db.mjs",
    "db:migrate-student-ids": "node prisma/scripts/migrate-student-ids.js",
    "test:smtp": "npm run test:smtp --prefix frontend"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "better-auth": "^1.6.15"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prisma": "^6.9.0"
  }
}
