generator client {
  provider = "prisma-client-js"
  output   = "../frontend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                     @id @default(uuid()) @db.Uuid
  fullName                  String                     @map("full_name") @db.VarChar(255)
  email                     String?                    @unique @db.VarChar(255)
  phone                     String?                    @db.VarChar(20)
  role                      Role
  password                  String
  isActive                  Boolean                    @default(true) @map("is_active")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  bio                       String?
  learningGoals             String?                    @map("learning_goals")
  socialLinks               String?                    @map("social_links") @db.VarChar(500)
  achievements              String?
  profileImage              String?                    @map("profile_image") @db.VarChar(500)
  lastLoginAt               DateTime?                  @map("last_login_at")
  admin                     Admin?
  comments                  Comment[]
  contentComments           ContentComment[]
  contentLikes              ContentLike[]
  lecturerMessageBroadcasts LecturerMessageBroadcast[] @relation("LecturerMessageBroadcasts")
  lecturer                  Lecturer?
  liveClassChatMessages     LiveClassChatMessage[]
  portalChatMessages        PortalChatMessage[]    @relation("PortalChatSender")
  chatGroupsCreated         ChatGroup[]            @relation("ChatGroupCreator")
  chatGroupMemberships      ChatGroupMember[]      @relation("ChatGroupMemberships")
  portalChatThreadReads   PortalChatThreadRead[]
  notifications             Notification[]
  studentMessageBroadcasts  StudentMessageBroadcast[]  @relation("StudentMessageBroadcasts")
  student                   Student?
  activityLogs              ActivityLog[]              @relation("ActivityLogs")
  systemSettingUpdates      SystemSetting[]            @relation("SystemSettingUpdates")
  passwordResetTokens       PasswordResetToken[]
  recordedPayments          Payment[]              @relation("PaymentRecordedBy")
  academicCalendarEvents    AcademicCalendarEvent[] @relation("CalendarEventCreator")
  liveClassesCreated        LiveClass[]             @relation("LiveClassCreator")

  @@map("users")
}

model AdmittedStudent {
  id            String      @id @default(uuid()) @db.Uuid
  studentId     String      @unique @map("student_id") @db.VarChar(50)
  fullName      String      @map("full_name") @db.VarChar(255)
  departmentId  String?     @map("department_id") @db.Uuid
  programId     String?     @map("program_id") @db.Uuid
  level         String?     @db.VarChar(50)
  semester      String?     @db.VarChar(50)
  gender        String?     @db.VarChar(20)
  admissionYear String?     @map("admission_year") @db.VarChar(10)
  createdAt     DateTime    @default(now()) @map("created_at")
  registeredAt  DateTime?   @map("registered_at")
  department    Department? @relation(fields: [departmentId], references: [id])
  program       Program?    @relation(fields: [programId], references: [id])

  @@index([studentId], map: "idx_admitted_students_student_id")
  @@map("admitted_students")
}

model Student {
  id                  String                   @id @default(uuid()) @db.Uuid
  userId              String                   @unique @map("user_id") @db.Uuid
  studentId           String                   @unique @map("student_id") @db.VarChar(50)
  departmentId        String?                  @map("department_id") @db.Uuid
  programId           String?                  @map("program_id") @db.Uuid
  level               String?                  @db.VarChar(50)
  semester            String?                  @db.VarChar(50)
  gender              String?                  @db.VarChar(20)
  admissionYear       String?                  @map("admission_year") @db.VarChar(10)
  profileImage        String?                  @map("profile_image")
  createdAt           DateTime                 @default(now()) @map("created_at")
  aiChatHistory       AiChatHistory[]
  attendance          Attendance[]
  courseStudents      CourseStudent[]
  discussions         Discussion[]
  liveClassAttendance LiveClassAttendanceLog[]
  liveClassHandRaises LiveClassHandRaise[]
  liveClassLateAdmits LiveClassLateAdmission[]
  liveClassPollVotes  LiveClassPollVote[]
  feeAccounts         StudentFeeAccount[]
  quizAttempts        QuizAttempt[]
  preferences         StudentPreference[]
  department          Department?              @relation(fields: [departmentId], references: [id])
  program             Program?                 @relation(fields: [programId], references: [id])
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions         Submission[]

  @@index([studentId], map: "idx_students_student_id")
  @@map("students")
}

model StudentPreference {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  prefKey   String   @map("pref_key") @db.VarChar(120)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, prefKey])
  @@index([studentId], map: "idx_student_preferences_student")
  @@map("student_preferences")
}

model Lecturer {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @unique @map("user_id") @db.Uuid
  staffId        String?       @unique @map("staff_id") @db.VarChar(50)
  specialization String?       @db.VarChar(255)
  isVerified     Boolean       @default(false) @map("is_verified")
  profileImage   String?       @map("profile_image")
  createdAt      DateTime      @default(now()) @map("created_at")
  assignments    Assignment[]
  courses        Course[]
  lectureNotes   LectureNote[]
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveClasses    LiveClass[]
  quizzes        Quiz[]
  videos         Video[]

  @@map("lecturers")
}

model Admin {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  adminLevel String?  @map("admin_level") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Department {
  id               String            @id @default(uuid()) @db.Uuid
  departmentName   String            @map("department_name") @db.VarChar(255)
  createdAt        DateTime          @default(now()) @map("created_at")
  description      String?
  admittedStudents AdmittedStudent[]
  courses          Course[]
  programs         Program[]
  students         Student[]
  feeStructures    FeeStructure[]

  @@map("departments")
}

model Program {
  id               String            @id @default(uuid()) @db.Uuid
  departmentId     String?           @map("department_id") @db.Uuid
  programName      String            @map("program_name") @db.VarChar(255)
  duration         String?           @db.VarChar(50)
  createdAt        DateTime          @default(now()) @map("created_at")
  admittedStudents AdmittedStudent[]
  courses          Course[]
  feeStructures    FeeStructure[]
  department       Department?       @relation(fields: [departmentId], references: [id])
  students         Student[]

  @@map("programs")
}

model Course {
  id               String          @id @default(uuid()) @db.Uuid
  lecturerId       String?         @map("lecturer_id") @db.Uuid
  departmentId     String?         @map("department_id") @db.Uuid
  programId        String?         @map("program_id") @db.Uuid
  courseTitle      String          @map("course_title") @db.VarChar(255)
  courseCode       String          @unique @map("course_code") @db.VarChar(50)
  semester         String?         @db.VarChar(50)
  level            String?         @db.VarChar(50)
  description      String?
  createdAt        DateTime        @default(now()) @map("created_at")
  learningOutcomes String?         @map("learning_outcomes")
  syllabusUrl      String?         @map("syllabus_url")
  syllabusText     String?         @map("syllabus_text")
  assignments      Assignment[]
  courseStudents   CourseStudent[]
  department       Department?     @relation(fields: [departmentId], references: [id])
  lecturer         Lecturer?       @relation(fields: [lecturerId], references: [id])
  program          Program?        @relation(fields: [programId], references: [id])
  discussions      Discussion[]
  lectureNotes     LectureNote[]
  liveClasses      LiveClass[]
  portalChatMessages PortalChatMessage[]
  quizzes          Quiz[]
  videos           Video[]

  @@index([courseCode], map: "idx_courses_course_code")
  @@map("courses")
}

model CourseStudent {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@map("course_students")
}

model LectureNote {
  id            String    @id @default(uuid()) @db.Uuid
  courseId      String    @map("course_id") @db.Uuid
  lecturerId    String?   @map("lecturer_id") @db.Uuid
  title         String    @db.VarChar(255)
  fileUrl       String    @map("file_url")
  fileType      String?   @map("file_type") @db.VarChar(20)
  description   String?
  createdAt     DateTime  @default(now()) @map("created_at")
  coverImageUrl String?   @map("cover_image_url")
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecturer      Lecturer? @relation(fields: [lecturerId], references: [id])

  @@map("lecture_notes")
}

model Video {
  id             String    @id @default(uuid()) @db.Uuid
  courseId       String    @map("course_id") @db.Uuid
  lecturerId     String?   @map("lecturer_id") @db.Uuid
  title          String?   @db.VarChar(255)
  videoUrl       String    @map("video_url")
  thumbnailUrl   String?   @map("thumbnail_url")
  duration       String?   @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime? @map("expires_at")
  deletionNotice String?   @map("deletion_notice")
  course         Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecturer       Lecturer? @relation(fields: [lecturerId], references: [id])

  @@map("videos")
}

model Quiz {
  id              String         @id @default(uuid()) @db.Uuid
  courseId        String         @map("course_id") @db.Uuid
  lecturerId      String?        @map("lecturer_id") @db.Uuid
  title           String?        @db.VarChar(255)
  instructions    String?
  durationMinutes Int?           @map("duration_minutes")
  totalMarks      Int?           @map("total_marks")
  createdAt       DateTime       @default(now()) @map("created_at")
  quizAttempts    QuizAttempt[]
  questions       QuizQuestion[]
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecturer        Lecturer?      @relation(fields: [lecturerId], references: [id])

  @@map("quizzes")
}

model QuizQuestion {
  id            String  @id @default(uuid()) @db.Uuid
  quizId        String  @map("quiz_id") @db.Uuid
  question      String
  optionA       String? @map("option_a")
  optionB       String? @map("option_b")
  optionC       String? @map("option_c")
  optionD       String? @map("option_d")
  correctAnswer String? @map("correct_answer") @db.VarChar(10)
  marks         Int     @default(1)
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  quizId      String   @map("quiz_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  score       Int?
  submittedAt DateTime @default(now()) @map("submitted_at")
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  @@index([studentId], map: "idx_quiz_attempts_student")
  @@map("quiz_attempts")
}

model Assignment {
  id            String       @id @default(uuid()) @db.Uuid
  courseId      String       @map("course_id") @db.Uuid
  lecturerId    String?      @map("lecturer_id") @db.Uuid
  title         String?      @db.VarChar(255)
  instructions  String?
  dueDate       DateTime?    @map("due_date")
  attachmentUrl String?      @map("attachment_url")
  createdAt     DateTime     @default(now()) @map("created_at")
  course        Course       @relation(fields: [courseId], references: [id])
  lecturer      Lecturer?    @relation(fields: [lecturerId], references: [id])
  submissions   Submission[]

  @@map("assignments")
}

model Submission {
  id           String     @id @default(uuid()) @db.Uuid
  assignmentId String     @map("assignment_id") @db.Uuid
  studentId    String     @map("student_id") @db.Uuid
  fileUrl      String?    @map("file_url")
  grade        String?    @db.VarChar(20)
  feedback     String?
  submittedAt  DateTime   @default(now()) @map("submitted_at")
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  student      Student    @relation(fields: [studentId], references: [id])

  @@map("submissions")
}

model Discussion {
  id             String         @id @default(uuid()) @db.Uuid
  courseId       String?        @map("course_id") @db.Uuid
  studentId      String?        @map("student_id") @db.Uuid
  title          String?        @db.VarChar(255)
  message        String?
  discussionType DiscussionType @map("discussion_type")
  createdAt      DateTime       @default(now()) @map("created_at")
  comments       Comment[]
  course         Course?        @relation(fields: [courseId], references: [id])
  student        Student?       @relation(fields: [studentId], references: [id])

  @@map("discussions")
}

model Comment {
  id           String     @id @default(uuid()) @db.Uuid
  discussionId String     @map("discussion_id") @db.Uuid
  userId       String?    @map("user_id") @db.Uuid
  comment      String
  createdAt    DateTime   @default(now()) @map("created_at")
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id])

  @@map("comments")
}

model ContentComment {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  targetType ContentTargetType @map("target_type")
  targetId   String            @map("target_id") @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  body       String
  createdAt  DateTime          @default(now()) @map("created_at")
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId], map: "idx_content_comments_target")
  @@map("content_comments")
}

model ContentLike {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  targetType ContentTargetType @map("target_type")
  targetId   String            @map("target_id") @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  createdAt  DateTime          @default(now()) @map("created_at")
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, userId], map: "uq_content_likes_target_user")
  @@map("content_likes")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  title     String?   @db.VarChar(255)
  message   String?
  targetUrl String?   @map("target_url") @db.VarChar(500)
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")
  user      User?     @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_notifications_user")
  @@index([userId, readAt], map: "idx_notifications_user_read_at")
  @@map("notifications")
}

model StudentMessageBroadcast {
  id             String   @id @default(uuid()) @db.Uuid
  title          String   @db.VarChar(255)
  message        String
  audienceType   String   @map("audience_type") @db.VarChar(50)
  audienceLabel  String   @map("audience_label") @db.VarChar(255)
  recipientCount Int      @default(0) @map("recipient_count")
  sentByUserId   String?  @map("sent_by_user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  sentBy         User?    @relation("StudentMessageBroadcasts", fields: [sentByUserId], references: [id])

  @@index([createdAt], map: "idx_student_message_broadcasts_created")
  @@map("student_message_broadcasts")
}

model LecturerMessageBroadcast {
  id             String   @id @default(uuid()) @db.Uuid
  title          String   @db.VarChar(255)
  message        String
  audienceType   String   @map("audience_type") @db.VarChar(50)
  audienceLabel  String   @map("audience_label") @db.VarChar(255)
  recipientCount Int      @default(0) @map("recipient_count")
  sentByUserId   String?  @map("sent_by_user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  sentBy         User?    @relation("LecturerMessageBroadcasts", fields: [sentByUserId], references: [id])

  @@index([createdAt], map: "idx_lecturer_message_broadcasts_created")
  @@map("lecturer_message_broadcasts")
}

model AiChatHistory {
  id         String   @id @default(uuid()) @db.Uuid
  studentId  String?  @map("student_id") @db.Uuid
  question   String?
  aiResponse String?  @map("ai_response")
  createdAt  DateTime @default(now()) @map("created_at")
  student    Student? @relation(fields: [studentId], references: [id])

  @@map("ai_chat_history")
}

enum LiveClassAudience {
  GENERAL
  STUDENTS
  LECTURERS
}

model LiveClass {
  id             String                   @id @default(uuid()) @db.Uuid
  courseId       String?                  @map("course_id") @db.Uuid
  lecturerId     String?                  @map("lecturer_id") @db.Uuid
  audience       LiveClassAudience        @default(GENERAL)
  meetingLink    String?                  @map("meeting_link")
  startTime      DateTime?                @map("start_time")
  endTime        DateTime?                @map("end_time")
  createdAt      DateTime                 @default(now()) @map("created_at")
  title          String?                  @db.VarChar(255)
  description    String?
  status         LiveClassStatus          @default(SCHEDULED)
  roomName       String?                  @unique @map("room_name") @db.VarChar(120)
  recordingUrl   String?                  @map("recording_url")
  actualStart    DateTime?                @map("actual_start")
  actualEnd      DateTime?                @map("actual_end")
  attendance     Attendance[]
  attendanceLogs LiveClassAttendanceLog[]
  chatMessages   LiveClassChatMessage[]
  handRaises     LiveClassHandRaise[]
  lateAdmissions LiveClassLateAdmission[]
  polls          LiveClassPoll[]
  recordings     LiveClassRecording[]
  course         Course?                  @relation(fields: [courseId], references: [id])
  lecturer       Lecturer?                @relation(fields: [lecturerId], references: [id])
  portalChatMessages PortalChatMessage[]
  createdById        String?                  @map("created_by_id") @db.Uuid
  createdBy          User?                    @relation("LiveClassCreator", fields: [createdById], references: [id])

  @@index([status, startTime], map: "idx_live_classes_status_start")
  @@index([audience, status], map: "idx_live_classes_audience_status")
  @@map("live_classes")
}

model LiveClassAttendanceLog {
  id                String           @id @default(uuid()) @db.Uuid
  liveClassId       String           @map("live_class_id") @db.Uuid
  studentId         String           @map("student_id") @db.Uuid
  studentIdCode     String           @map("student_id_code") @db.VarChar(50)
  studentName       String           @map("student_name") @db.VarChar(255)
  courseCode        String           @map("course_code") @db.VarChar(50)
  courseTitle       String           @map("course_title") @db.VarChar(255)
  joinTime          DateTime         @map("join_time")
  exitTime          DateTime?        @map("exit_time")
  durationSeconds   Int              @default(0) @map("duration_seconds")
  attendancePercent Float            @default(0) @map("attendance_percent")
  status            AttendanceStatus @default(ABSENT)
  updatedAt         DateTime         @updatedAt @map("updated_at")
  liveClass         LiveClass        @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([liveClassId, studentId])
  @@index([liveClassId], map: "idx_live_attendance_class")
  @@map("live_class_attendance_logs")
}

model LiveClassChatMessage {
  id          String    @id @default(uuid()) @db.Uuid
  liveClassId String    @map("live_class_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  senderName  String    @map("sender_name") @db.VarChar(255)
  senderRole  Role      @map("sender_role")
  message     String
  createdAt   DateTime  @default(now()) @map("created_at")
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([liveClassId, createdAt], map: "idx_live_chat_class_time")
  @@map("live_class_chat_messages")
}

model LiveClassPoll {
  id          String              @id @default(uuid()) @db.Uuid
  liveClassId String              @map("live_class_id") @db.Uuid
  question    String
  options     String
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  votes       LiveClassPollVote[]
  liveClass   LiveClass           @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@map("live_class_polls")
}

model LiveClassPollVote {
  id          String        @id @default(uuid()) @db.Uuid
  pollId      String        @map("poll_id") @db.Uuid
  studentId   String        @map("student_id") @db.Uuid
  optionIndex Int           @map("option_index")
  createdAt   DateTime      @default(now()) @map("created_at")
  poll        LiveClassPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([pollId, studentId])
  @@map("live_class_poll_votes")
}

model LiveClassHandRaise {
  id          String    @id @default(uuid()) @db.Uuid
  liveClassId String    @map("live_class_id") @db.Uuid
  studentId   String    @map("student_id") @db.Uuid
  studentName String    @map("student_name") @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([liveClassId, studentId])
  @@map("live_class_hand_raises")
}

model LiveClassRecording {
  id           String    @id @default(uuid()) @db.Uuid
  liveClassId  String    @map("live_class_id") @db.Uuid
  title        String    @db.VarChar(255)
  recordingUrl String    @map("recording_url")
  durationSec  Int?      @map("duration_sec")
  createdAt    DateTime  @default(now()) @map("created_at")
  liveClass    LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@map("live_class_recordings")
}

model LiveClassLateAdmission {
  id          String    @id @default(uuid()) @db.Uuid
  liveClassId String    @map("live_class_id") @db.Uuid
  studentId   String    @map("student_id") @db.Uuid
  approvedAt  DateTime  @default(now()) @map("approved_at")
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([liveClassId, studentId])
  @@index([liveClassId], map: "idx_live_late_admit_class")
  @@map("live_class_late_admissions")
}

model AcademicCalendarEvent {
  id          String              @id @default(uuid()) @db.Uuid
  title       String              @db.VarChar(255)
  description String?
  startAt     DateTime            @map("start_at")
  endAt       DateTime?           @map("end_at")
  eventType   CalendarEventType   @default(ACTIVITY) @map("event_type")
  audience    CalendarAudience    @default(ALL)
  location    String?             @db.VarChar(255)
  createdById String?             @map("created_by_id") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  createdBy   User?               @relation("CalendarEventCreator", fields: [createdById], references: [id])

  @@index([startAt], map: "idx_calendar_events_start")
  @@map("academic_calendar_events")
}

model Attendance {
  id        String           @id @default(uuid()) @db.Uuid
  classId   String?          @map("class_id") @db.Uuid
  studentId String?          @map("student_id") @db.Uuid
  status    AttendanceStatus
  markedAt  DateTime         @default(now()) @map("marked_at")
  liveClass LiveClass?       @relation(fields: [classId], references: [id])
  student   Student?         @relation(fields: [studentId], references: [id])

  @@map("attendance")
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.VarChar(100)
  summary    String?  @db.VarChar(500)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  actor      User?    @relation("ActivityLogs", fields: [actorId], references: [id])

  @@index([createdAt], map: "idx_activity_logs_created")
  @@index([actorId], map: "idx_activity_logs_actor")
  @@map("activity_logs")
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  value     Json
  label     String?  @db.VarChar(255)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Uuid
  updater   User?    @relation("SystemSettingUpdates", fields: [updatedBy], references: [id])

  @@map("system_settings")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_password_reset_tokens_user")
  @@index([tokenHash], map: "idx_password_reset_tokens_hash")
  @@map("password_reset_tokens")
}

model FeeStructure {
  id           String              @id @default(uuid()) @db.Uuid
  title        String              @db.VarChar(255)
  amount       Decimal             @db.Decimal(12, 2)
  currency     String              @default("SLE") @db.VarChar(10)
  programId    String?             @map("program_id") @db.Uuid
  departmentId String?             @map("department_id") @db.Uuid
  level        String?             @db.VarChar(50)
  semester     String?             @db.VarChar(50)
  intakeBatch  String?             @map("intake_batch") @db.VarChar(50)
  dueDate      DateTime?           @map("due_date")
  requiredPaymentPercent Float     @default(100) @map("required_payment_percent")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  program      Program?            @relation(fields: [programId], references: [id])
  department   Department?         @relation(fields: [departmentId], references: [id])
  accounts     StudentFeeAccount[]

  @@index([isActive, dueDate], map: "idx_fee_structures_active_due")
  @@map("fee_structures")
}

model StudentFeeAccount {
  id             String           @id @default(uuid()) @db.Uuid
  studentId      String           @map("student_id") @db.Uuid
  feeStructureId String           @map("fee_structure_id") @db.Uuid
  totalAmount    Decimal          @map("total_amount") @db.Decimal(12, 2)
  amountPaid     Decimal          @default(0) @map("amount_paid") @db.Decimal(12, 2)
  status         FeePaymentStatus @default(UNPAID)
  dueDate        DateTime?        @map("due_date")
  requiredPaymentPercent Float?   @map("required_payment_percent")
  temporaryAccessUntil DateTime?  @map("temporary_access_until")
  restrictionOverridden Boolean   @default(false) @map("restriction_overridden")
  lastReminderAt DateTime?        @map("last_reminder_at")
  accessLocked   Boolean          @default(false) @map("access_locked")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure   FeeStructure     @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  payments       Payment[]
  invoices       FeeInvoice[]

  @@unique([studentId, feeStructureId])
  @@index([status], map: "idx_student_fee_accounts_status")
  @@index([studentId], map: "idx_student_fee_accounts_student")
  @@map("student_fee_accounts")
}

model Payment {
  id                  String            @id @default(uuid()) @db.Uuid
  studentFeeAccountId String            @map("student_fee_account_id") @db.Uuid
  amount              Decimal           @db.Decimal(12, 2)
  method              String?           @db.VarChar(50)
  reference           String?           @db.VarChar(120)
  receiptNumber       String            @unique @map("receipt_number") @db.VarChar(50)
  recordedById        String?           @map("recorded_by_id") @db.Uuid
  notes               String?
  paidAt              DateTime          @map("paid_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  studentFeeAccount   StudentFeeAccount @relation(fields: [studentFeeAccountId], references: [id], onDelete: Cascade)
  recordedBy          User?             @relation("PaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([studentFeeAccountId, paidAt], map: "idx_payments_account_paid_at")
  @@map("payments")
}

model FeeInvoice {
  id                  String            @id @default(uuid()) @db.Uuid
  studentFeeAccountId String            @map("student_fee_account_id") @db.Uuid
  invoiceNumber       String            @unique @map("invoice_number") @db.VarChar(50)
  issuedAt            DateTime          @default(now()) @map("issued_at")
  studentFeeAccount   StudentFeeAccount @relation(fields: [studentFeeAccountId], references: [id], onDelete: Cascade)

  @@map("fee_invoices")
}

enum PortalChatKind {
  COURSE
  DIRECT
  GROUP
  LIVE_CLASS
}

enum PortalChatMessageType {
  TEXT
  VOICE
}

model ChatGroup {
  id          String            @id @default(uuid()) @db.Uuid
  name        String            @db.VarChar(120)
  description String?
  createdById String            @map("created_by_id") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  createdBy   User              @relation("ChatGroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     ChatGroupMember[]
  messages    PortalChatMessage[]

  @@index([createdById], map: "idx_chat_groups_creator")
  @@map("chat_groups")
}

model ChatGroupMember {
  id       String    @id @default(uuid()) @db.Uuid
  groupId  String    @map("group_id") @db.Uuid
  userId   String    @map("user_id") @db.Uuid
  joinedAt DateTime  @default(now()) @map("joined_at")
  group    ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation("ChatGroupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId], map: "idx_chat_group_members_user")
  @@map("chat_group_members")
}

model PortalChatMessage {
  id          String                @id @default(uuid()) @db.Uuid
  kind        PortalChatKind
  messageType PortalChatMessageType @default(TEXT) @map("message_type")
  courseId    String?               @map("course_id") @db.Uuid
  groupId     String?               @map("group_id") @db.Uuid
  liveClassId String?               @map("live_class_id") @db.Uuid
  threadKey   String                @map("thread_key") @db.VarChar(160)
  senderId    String                @map("sender_id") @db.Uuid
  body        String                @default("")
  audioData   String?               @map("audio_data")
  isPinned    Boolean               @default(false) @map("is_pinned")
  isHighlighted Boolean             @default(false) @map("is_highlighted")
  deletedAt   DateTime?             @map("deleted_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  sender    User           @relation("PortalChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  course    Course?        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  group     ChatGroup?     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  liveClass LiveClass?     @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@index([threadKey, createdAt], map: "idx_portal_chat_thread_time")
  @@index([courseId, createdAt], map: "idx_portal_chat_course_time")
  @@index([groupId, createdAt], map: "idx_portal_chat_group_time")
  @@index([liveClassId, createdAt], map: "idx_portal_chat_live_class_time")
  @@map("portal_chat_messages")
}

model PortalChatThreadRead {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  threadKey  String   @map("thread_key") @db.VarChar(160)
  lastReadAt DateTime @map("last_read_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, threadKey])
  @@index([userId], map: "idx_portal_chat_reads_user")
  @@map("portal_chat_thread_reads")
}

enum Role {
  STUDENT
  LECTURER
  ADMIN
}

enum DiscussionType {
  COURSE
  PROGRAM
  GENERAL
}

enum ContentTargetType {
  LECTURE_NOTE
  VIDEO
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  PARTIAL
}

enum LiveClassStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum FeePaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum CalendarEventType {
  ACADEMIC
  EXAM
  REGISTRATION
  HOLIDAY
  ACTIVITY
  OTHER
}

enum CalendarAudience {
  ALL
  STUDENTS
  LECTURERS
  ADMIN
}
