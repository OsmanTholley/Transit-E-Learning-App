# PostgreSQL connection string used by Prisma (root .env — loaded by Next.js from ../.env).
#
# --- Local development (recommended) ---
# Install PostgreSQL, create a database, then use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transit_elearning?schema=public"
#
# Then run from project root:
#   npx prisma migrate deploy
#   npm run db:seed
#
# --- Prisma Postgres (cloud) ---
# Copy the full connection string from: https://console.prisma.io → your project → Connect
# If you see "Can't reach database server at db.prisma.io", the project may be paused,
# the URL may be expired, or your network may block the host — try local Postgres instead.
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transit_elearning?schema=public"

# App URL (CORS for Socket.io)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Live classroom real-time server (Socket.io)
LIVE_CLASSROOM_SOCKET_PORT=3001
NEXT_PUBLIC_LIVE_CLASSROOM_SOCKET_URL="http://localhost:3001"

# LiveKit — HD video, screen share, recording (optional; collaboration mode works without it)
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"
