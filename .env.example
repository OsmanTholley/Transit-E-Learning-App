# PostgreSQL connection string (Neon recommended for production).
# Create a project at https://console.neon.tech → Connection Details → copy the pooled URL.
#
# Keep this file at the project ROOT only. Do not create frontend/.env — Next.js loads
# this file via frontend/next.config.ts. A stale frontend/.env overrides Neon with db.prisma.io.
#
# Then run from project root (where .env lives):
#   npm run db:migrate
#   npm run db:generate
#   npm run db:seed
#
# From frontend/ you can use the same via npm (proxies to root):
#   npm run db:migrate
#   npm run db:generate
#
# Do not run bare `npx prisma generate` from frontend/ — it may pick the wrong
# schema or Prisma version. Always use npm scripts or run from the project root.
#
#Neon Online database
#connet your app with one command
#npx neonctl@latest init


#Connect your app manually
#postgresql://neondb_owner:npg_5OPcbIKQTmj7@ep-old-truth-apdubwtq.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# --- Ollama (local AI tutor) ---
# Install from https://ollama.com then pull models:
#   ollama run gemma4:e4b
#   ollama run deepseek-r1:8b
#   ollama run gpt-oss:20b
OLLAMA_BASE_URL="http://127.0.0.1:11434"

# --- YouTube Data API v3 (student video suggestions) ---
# Get your key from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable "YouTube Data API v3" in your project, then paste the key here.
# If left blank, the YouTube suggestions section is silently hidden.
YOUTUBE_API_KEY=""

# --- Email (password reset + announcement alerts) ---
# Required in production for self-service password reset.
#
# Option A — Resend (recommended): https://resend.com → API Keys
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"
#
# Option B — Gmail SMTP (SMTP_USER must be the real @gmail.com address)
# App Password: https://myaccount.google.com/apppasswords
# Test: npm run test:smtp
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="youraccount@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM="Transit E-Learning <youraccount@gmail.com>"

# Public URL of the app (used in password-reset links).
APP_BASE_URL="http://localhost:3000"

# Optional display name in outbound emails.
PLATFORM_NAME="Transit E-Learning"

# --- Google OAuth (staff sign-in at /login?role=staff) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Virtual classroom (Jitsi) ---
# Free hosted video: meet.jit.si (default). Use your own Jitsi domain for production.
JITSI_DOMAIN="meet.jit.si"
